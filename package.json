{
  "name": "MyApp",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0",
    "rimraf": "^5.0.5",
    "mbt": "^1.2.29"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-myfrontapp": "cds watch --open com.myfrontapp/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy MyApp --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1",
    "watch-ui2": "cds watch --open com.ram.ui2/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "cds": {
    "requires": {
      "[production]": {
        "auth": "xsuaa"
      },
      "db": {
        "[development]": {
          "kind": "sqlite",
          "schema_evolution": "auto",
          "credentials": {
            "url": "myapp"
          }
        }
      },
      "auth": {
        "[development]": {
          "kind": "basic",
          "users": {
            "salesUser": {
              "password": "sale@123",
              "roles": [
                "SalesUser"
              ],
              "attr": {
                "country": "IN"
              }
            },
            "masterUser": {
              "password": "master@123",
              "roles": [
                "MasterDataUser"
              ],
              "attr": {
                "country": "US"
              }
            },
            "adminUser": {
              "password": "admin@123",
              "roles": [
                "Admin"
              ]
            }
          }
        }
      },
      "destinations": true,
      "html5-repo": true
    }
  },
  "i18n": {
    "default_language": "en",
    "languages": [
      "en"
    ]
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/myfrontapp",
    "app/ui2"
  ]
}
